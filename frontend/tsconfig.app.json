{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "jsx": "react-jsx",
    "lib": ["dom", "es2022"],
    "types": [
      "node",
      "@nx/react/typings/cssmodule.d.ts",
      "@nx/react/typings/image.d.ts",
      "vite/client"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false
  },
  "exclude": [
    "out-tsc",
    "dist",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.tsx",
    "src/**/*.test.tsx",
    "vite.config.ts",
    "vite.config.mts",
    "vitest.config.ts",
    "vitest.config.mts",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs",
    "../modules/inventory-ui/src/**/*.spec.tsx",
    "../modules/inventory-ui/src/**/*.test.tsx",
    "../modules/inventory-ui/src/**/*.spec.ts",
    "../modules/inventory-ui/src/**/*.test.ts",
    "../modules/sales-ui/src/**/*.spec.tsx",
    "../modules/sales-ui/src/**/*.test.tsx",
    "../modules/sales-ui/src/**/*.spec.ts",
    "../modules/sales-ui/src/**/*.test.ts",
    "../modules/purchasing-ui/src/lib/**/*.ts",
"../modules/purchasing-ui/src/lib/**/*.tsx",
"../modules/purchasing-ui/src/index.ts"
  ],
  "include": [
    "src/**/*.js",
    "src/**/*.jsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "../modules/inventory-ui/src/lib/**/*.ts",
    "../modules/inventory-ui/src/lib/**/*.tsx",
    "../modules/inventory-ui/src/index.ts",
    "../modules/sales-ui/src/lib/**/*.ts",
    "../modules/sales-ui/src/lib/**/*.tsx",
    "../modules/sales-ui/src/index.ts"
  ],
  "references": [
    {
      "path": "../modules/sales-ui/tsconfig.lib.json"
    },
    {
      "path": "../modules/inventory-ui/tsconfig.lib.json"
    },
    { "path": "../modules/purchasing-ui/tsconfig.lib.json" }
  ]
}