{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "types": ["node"],
    "rootDir": "src",
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2021"
  },
  "include": ["src/**/*.ts", "../modules/purchasing/src/**/*.ts"],
  "exclude": [
    "out-tsc",
    "dist",
    "jest.config.ts",
    "jest.config.cts",
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ],
  "references": [
    {
      "path": "../modules/accounting/tsconfig.lib.json"
    },
    {
      "path": "../modules/purchasing/tsconfig.lib.json"
    },
    {
      "path": "../modules/sales/tsconfig.lib.json"
    },
    {
      "path": "../modules/inventory/tsconfig.lib.json"
    },
    {
      "path": "../core/tsconfig.lib.json"
    }
  ]
}
