{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "types": ["node"],
    "customConditions": ["@org/source"],
    "paths": {
  "@org/core": ["./core/src/index.ts"],
  "@org/api": ["./frontend/src/core/api/axios.config.ts"],
  "@org/core-api": ["./frontend/src/core/api/core.api.ts"],
  "@org/inventory": ["./modules/inventory/src/index.ts"],
  "@org/inventory-ui": ["./modules/inventory-ui/src/index.ts"],
  "@org/sales": ["./modules/sales/src/index.ts"],
  "@org/sales-ui": ["./modules/sales-ui/src/index.ts"],
  "@org/purchasing": ["./modules/purchasing/src/index.ts"],
  "@org/purchasing-ui": ["./modules/purchasing-ui/src/index.ts"],
  "@org/accounting": ["./modules/accounting/src/index.ts"],
  "@org/accounting-ui": ["./modules/accounting-ui/src/index.ts"],
  "@org/prisma": ["./generated/prisma"]
}
  }
}