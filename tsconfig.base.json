{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "types": ["node"],
    "customConditions": ["@org/source"],
    "paths": {
      "@org/core": ["./core/src/index.ts"],
      "@org/inventory": ["./modules/inventory/src/index.ts"],
      "@org/inventory-ui": ["./modules/inventory-ui/src/index.ts"]
    }
  }
}